# OpenClaw launch profile (template)
# Copy to: config/launch.env  (ignored by git)
#   Format: KEY=VALUE  (no quotes, # comments OK)
#   Reload: stop.bat then start.bat
#   Doc: docs/SYSTEM_RUNBOOK.md §0

# --- Port (default: 18080 from src/openclaw_env.py) ---
# Set to 8000 to preserve historical behavior (existing dashboard URL)
OPENCLAW_PORT=8000

# --- Bind address (default: 0.0.0.0 = LAN reachable) ---
# Set to 127.0.0.1 only if you want to restrict to localhost (RUNBOOK F1)
# OPENCLAW_HOST=0.0.0.0

# --- TLS (default: off) ---
# Set to 1 to enable HTTPS using config/certs/server.{key,crt}
# OPENCLAW_TLS=0

# --- API key (default: off, see RUNBOOK §3) ---
# OPENCLAW_API_KEY=

# --- L2 central customer store (PostgreSQL) ---
# OPENCLAW_PG_HOST=127.0.0.1
# OPENCLAW_PG_PORT=5432
# OPENCLAW_PG_DB=openclaw
# OPENCLAW_PG_USER=openclaw_app
# OPENCLAW_PG_PASSWORD=                     # MUST be ASCII-only (RUNBOOK F9)

# --- Disable device health monitor ---
# OPENCLAW_DISABLE_DEVICE_HEALTH_MONITOR=0

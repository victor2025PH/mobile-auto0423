# OpenClaw 环境变量配置模板
# 复制为 .env 并填写实际值

# === AI/LLM ===
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# === API 安全 ===
OPENCLAW_API_KEY=              # API 鉴权密钥，为空则不启用
OPENCLAW_SESSION_TOKEN=        # 会话令牌
# Facebook：POST /facebook/active-persona 仅接受 X-API-Key==OPENCLAW_API_KEY（公网收紧写盘）
# OPENCLAW_FB_ACTIVE_PERSONA_REQUIRE_KEY=1

# TikTok：campaign 模式（无 flow_steps）若本地 devices.yaml 有该设备但非在线，是否不再转发 Worker-03（默认关）
# OPENCLAW_TT_CAMPAIGN_SKIP_WORKER_WHEN_OFFLINE=1

# 单测/脚本：跳过 HealthMonitor 设备心跳线程（生产勿设）
# OPENCLAW_DISABLE_DEVICE_HEALTH_MONITOR=1

# 单测/脚本：跳过启动时壁纸自动编号守护线程（生产勿设）
# OPENCLAW_DISABLE_AUTO_WALLPAPER_THREAD=1

# === 集群 ===
OPENCLAW_CLUSTER_SECRET=       # 集群通信密钥，为空则自动生成

# === CORS ===
OPENCLAW_CORS_ORIGINS=http://localhost:3000,http://localhost:18080

# === 限流 ===
OPENCLAW_RATE_LIMIT=6000       # 每分钟请求数上限

# === TLS ===
OPENCLAW_TLS=                  # 设置为 1/true 启用 HTTPS
OPENCLAW_HOST=0.0.0.0          # 监听地址
OPENCLAW_PORT=18080            # 监听端口（默认 18080，避免与常见 8000 冲突）
